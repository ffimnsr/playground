{
  "kind": "collectionType",
  "collectionName": "recipes",
  "info": {
    "singularName": "recipe",
    "pluralName": "recipes",
    "displayName": "Recipe",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "imageUrl": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "files",
        "images"
      ]
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "soup",
        "main",
        "side",
        "appetizer",
        "entree",
        "dessert",
        "salad"
      ]
    },
    "ingredientPortions": {
      "type": "json"
    },
    "instructions": {
      "type": "richtext"
    },
    "description": {
      "type": "text"
    },
    "servings": {
      "type": "integer"
    },
    "nutritionalInformation": {
      "type": "json"
    },
    "ingredients": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::recipe-ingredient.recipe-ingredient"
    },
    "cookingTime": {
      "type": "integer"
    },
    "preparationTime": {
      "type": "integer"
    }
  }
}
