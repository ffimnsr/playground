{
  "name": "wheat-bread",
  "version": "0.0.12",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "blueprint run",
    "compile": "blueprint build",
    "compile:all": "blueprint build --all",
    "clean": "rimraf build",
    "build": "run-s clean compile",
    "build:all": "run-s clean compile:all",
    "deploy:testnet": "blueprint run deploy_nft_collection --testnet --tonconnect",
    "deploy:mainnet": "blueprint run deploy_nft_collection --mainnet --tonconnect",
    "push:testnet": "run-s clean compile:all deploy:testnet",
    "push:mainnet": "run-s clean compile:all deploy:mainnet",
    "mint": "blueprint run mint_nft --testnet --tonconnect",
    "lint": "blueprint misti",
    "test": "jest --verbose",
    "prelib:build": "run-s clean build:all",
    "lib:build": "tsup",
    "postlib:build": "pnpm version patch"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@nowarp/blueprint-misti": "^0.5.0",
    "@ton/blueprint": "^0.25.0",
    "@ton/core": "~0",
    "@ton/crypto": "^3.3.0",
    "@ton/sandbox": "^0.22.0",
    "@ton/test-utils": "^0.4.2",
    "@ton/ton": "^15.1.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.8.7",
    "jest": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.14.4+sha512.c8180b3fbe4e4bca02c94234717896b5529740a6cbadf19fa78254270403ea2f27d4e1d46a08a0f56c89b63dc8ebfd3ee53326da720273794e6200fcf0d184ab",
  "dependencies": {
    "buffer": "^6.0.3"
  }
}
